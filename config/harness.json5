{
  // Model choice and model behavior defaults live in `models.json5` under
  // `roles`. Use `/model <role>` to switch and `/role ...` to edit
  // persisted role overrides.

  // Optional named per-role tool overlays. Each entry maps tool name to
  // enabled/disabled and overrides that tool's `enabled_by_default` hint.
  // toolsProfiles: {
  //   // Built in by default:
  //   // gpt: {
  //   //   apply_patch: true,
  //   //   edit: false,
  //   //   find: false,
  //   //   grep: false,
  //   //   ls: false,
  //   //   read: false,
  //   //   write: false,
  //   // },
  //   read_only: {
  //     shell: false,
  //     write: false,
  //     edit: false,
  //   },
  // },

  // Optional built-in extension overrides.
  // extensions: {
  //   "core-shell": { enable: false },
  //   "core-agent": { enable: false },
  //   "test-dummy": { enable: true },
  // },
}
